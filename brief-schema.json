{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Yoshi Labs Client Brief",
  "description": "Source of truth for every client build. Matches actual brief.json structure used by Claude Code.",
  "type": "object",
  "required": ["business_name", "slug", "industry", "location"],
  "properties": {
    "client_name": {
      "type": "string",
      "description": "Name of the client/person who commissioned the build."
    },
    "business_name": {
      "type": "string",
      "description": "Exact display name. Used in nav, hero h1, footer, SEO, chatbot greetings."
    },
    "industry": {
      "type": "string",
      "description": "Maps to industry model in .claude/skills/industry-designs/models/{industry}.yaml",
      "enum": [
        "accounting", "auto", "bakery", "cafe", "catering", "clinic",
        "construction", "creative-agency", "dental", "education",
        "event-planner", "fitness", "general", "gym", "hotel",
        "housekeeping", "law-firm", "medical", "photography",
        "real-estate", "repair", "restaurant", "retail", "salon",
        "spa", "tutorial", "veterinary"
      ]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-safe identifier. Folder name, Vercel subdomain."
    },
    "location": {
      "type": "string",
      "description": "City, country. Simple string format."
    },
    "contact": {
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "hours": { "type": "string" },
        "socials": {
          "type": "object",
          "properties": {
            "facebook": { "type": "string" },
            "instagram": { "type": "string" },
            "tiktok": { "type": "string" }
          }
        }
      }
    },
    "tagline": {
      "type": "string",
      "description": "One-line value prop for hero section."
    },
    "description": {
      "type": "string",
      "description": "1-2 sentence elevator pitch."
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "string" }
        }
      }
    },
    "pricing": {
      "type": "object",
      "properties": {
        "setup": { "type": "string" },
        "monthly": { "type": "string" },
        "contract": { "type": "string" }
      }
    },
    "about": {
      "type": "object",
      "properties": {
        "story": { "type": "string" },
        "team": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "role"],
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "bio": { "type": "string" },
              "photo": { "type": "string" }
            }
          }
        },
        "fun_facts": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "brand": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "bg": { "type": "string" },
            "bg_elevated_1": { "type": "string" },
            "bg_elevated_2": { "type": "string" },
            "border": { "type": "string" },
            "border_subtle": { "type": "string" },
            "text_primary": { "type": "string" },
            "text_secondary": { "type": "string" },
            "text_tertiary": { "type": "string" },
            "text_muted": { "type": "string" },
            "accent": { "type": "string" },
            "accent_blue": { "type": "string" },
            "accent_cyan": { "type": "string" },
            "success": { "type": "string" },
            "warning": { "type": "string" }
          }
        },
        "fonts": {
          "type": "object",
          "properties": {
            "heading": { "type": "string" },
            "body": { "type": "string" },
            "mono": { "type": "string" }
          }
        },
        "style": { "type": "string" },
        "gradient": { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of page sections."
    },
    "ctas": {
      "type": "object",
      "properties": {
        "primary": { "type": "string" },
        "secondary": { "type": "string" },
        "tertiary": { "type": "string" }
      }
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "answer"],
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" }
        }
      }
    },
    "competitors": { "type": "array", "items": { "type": "string" } },
    "testimonials": { "type": "array", "items": { "type": "object" } },
    "portfolio": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "refero_style": {
      "type": "string",
      "description": "Refero design system to use as quality benchmark."
    },
    "photos_needed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Descriptions for Higgsfield photo generation."
    },
    "deadline": { "type": "string" },
    "notes": { "type": "string" }
  }
}
